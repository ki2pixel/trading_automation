//@version=6
indicator("ML Liquidity Zone Classifier [PhenLabs]", shorttitle="ML LZC", overlay=true, max_boxes_count=500, max_labels_count=500)

// =============================================================
// === INPUTS ===
// =============================================================
knn_k          = input.int(5,    "K (neighbors)",                  minval=1,  group="KNN Classifier")
lookback       = input.int(100,  "Training window",                minval=10, group="KNN Classifier")

auto_htf       = input.bool(true, "Auto HTF (tailor to chart TF)",            group="HTF Alignment")
htf_mult       = input.float(12.0,"Auto HTF multiplier",           minval=2.0, step=1.0, group="HTF Alignment")
htf            = input.timeframe("D", "Manual HTF (used when auto is off)",   group="HTF Alignment")

volume_mult    = input.float(1.5, "Volume spike multiplier",       minval=0.1, step=0.1, group="Zone Detection")
ob_atr_mult    = input.float(1.5, "Order block ATR mult",          minval=0.1, step=0.1, group="Zone Detection")
zone_tolerance = input.float(0.1, "Equal H/L tolerance (ATR frac)", minval=0.01, step=0.01, group="Zone Detection")

// --- Zone quality gate (keeps zones few, clean + accurate) ---
min_conf       = input.int(65,    "Min confidence to draw a zone", minval=0, maxval=100, group="Zone Quality")
min_gap        = input.int(5,     "Min bars between zones",        minval=0, group="Zone Quality")
merge_atr      = input.float(0.75,"Merge distance (ATR)",          minval=0.0, step=0.25, group="Zone Quality")
max_zone_atr   = input.float(2.0, "Max zone height (ATR)",         minval=0.5, step=0.5, group="Zone Quality")
mitigate       = input.bool(true, "Remove zones when price breaks them",      group="Zone Quality")
max_zones      = input.int(6,     "Max visible zones",             minval=1,  group="Visualization")

// --- Advanced (sensible defaults, exposed for tuning) ---
atr_len        = input.int(14,    "ATR length",                    minval=1,   group="Advanced")
vol_len        = input.int(20,    "Volume average length",         minval=1,   group="Advanced")
vol_peak_len   = input.int(20,    "Volume node peak window",       minval=1,   group="Advanced")
pivot_len      = input.int(5,     "Pivot length (EQH/EQL)",        minval=1,   group="Advanced")
eval_window    = input.int(10,    "Label evaluation window",       minval=1,   group="Advanced")
eval_atr_mult  = input.float(1.0, "Label move threshold (ATR)",    minval=0.1, step=0.1, group="Advanced")
show_dashboard = input.bool(true, "Show dashboard",                            group="Visualization")

// =============================================================
// === STATE (var arrays for KNN training set + zone objects) ===
// =============================================================
// KNN training samples: 3 feature columns + 1 label column, kept in lock-step.
var array<float> trainF1    = array.new<float>()   // normalized volume feature
var array<float> trainF2    = array.new<float>()   // HTF alignment feature
var array<float> trainF3    = array.new<float>()   // order-block / displacement feature
var array<float> trainLabel = array.new<float>()   // 1.0 = high probability, 0.0 = low probability

// Rendered zone objects + parallel metadata (handle, top, bottom, direction)
// all kept in lock-step so a zone can be mitigated / pruned cleanly.
var array<box>   boxArr   = array.new<box>()
var array<label> labelArr = array.new<label>()
var array<float> zoneTop  = array.new<float>()
var array<float> zoneBot  = array.new<float>()
var array<bool>  zoneBull = array.new<bool>()

// Dashboard / cooldown state.
var string lastZoneType = "—"
var float  lastConf     = na
var int    lastZoneBar  = na

// =============================================================
// === HELPER FUNCTIONS ===
// =============================================================

// Map the current chart timeframe to a higher one ~ (mult x) the chart period,
// snapped to the nearest standard TF >= the target. Keeps HTF context
// proportional whether the user is on 1m, 1h, or daily.
f_autoHTF(float mult) =>
    float target = timeframe.in_seconds() * mult
    array<int>    secs = array.from(60, 180, 300, 900, 1800, 3600, 7200, 14400, 28800, 86400, 604800, 2592000)
    array<string> tfs  = array.from("1", "3", "5", "15", "30", "60", "120", "240", "480", "D", "W", "M")
    string res = "M"
    for i = 0 to array.size(secs) - 1
        if array.get(secs, i) >= target
            res := array.get(tfs, i)
            break
    res

// Background fill colour by confidence + direction (transparent so price stays visible).
zoneBg(float conf, bool isBull) =>
    conf >= 70 ? (isBull ? color.new(color.lime, 78) : color.new(color.red, 78)) : conf >= 40 ? color.new(color.orange, 82) : color.new(color.gray, 88)

// Solid border colour by confidence + direction.
zoneBorder(float conf, bool isBull) =>
    conf >= 70 ? (isBull ? color.lime : color.red) : conf >= 40 ? color.orange : color.gray

// KNN classifier -------------------------------------------------------------
// Given a query feature vector (qf1,qf2,qf3) returns a 0..100 confidence score:
// the share of the k nearest training samples that voted "high probability",
// using Euclidean distance across the normalized feature space.
knnConfidence(float qf1, float qf2, float qf3, int k) =>
    int n = array.size(trainLabel)
    float result = na
    if n > 0
        // 1) Euclidean distance from the query to every training sample.
        //    dist = sqrt( (df1)^2 + (df2)^2 + (df3)^2 ) per neighbour.
        array<float> dists = array.new<float>()
        for i = 0 to n - 1
            float d1 = qf1 - array.get(trainF1, i)
            float d2 = qf2 - array.get(trainF2, i)
            float d3 = qf3 - array.get(trainF3, i)
            array.push(dists, math.sqrt(d1 * d1 + d2 * d2 + d3 * d3))
        // 2) Select the k nearest by repeatedly extracting the current minimum
        //    distance (partial selection sort — cheap for small k / lookback).
        int kEff = math.min(k, n)
        array<bool> used = array.new<bool>(n, false)
        int votes = 0
        for j = 0 to kEff - 1
            float best = na
            int bestIdx = -1
            for i = 0 to n - 1
                if not array.get(used, i)
                    float dv = array.get(dists, i)
                    if na(best) or dv < best
                        best := dv
                        bestIdx := i
            if bestIdx >= 0
                array.set(used, bestIdx, true)
                votes += int(array.get(trainLabel, bestIdx))   // tally "high probability" votes
        // 3) Confidence = fraction of neighbours voting high probability, x100.
        result := votes / float(kEff) * 100.0
    result

// Create a zone box + score label and return both handles.
makeZone(float top, float bottom, int leftBar, float conf, bool isBull, string tag) =>
    color bg = zoneBg(conf, isBull)
    color bc = zoneBorder(conf, isBull)
    box b = box.new(leftBar, top, leftBar + 1, bottom, xloc=xloc.bar_index, border_color=bc, border_width=1, bgcolor=bg, extend=extend.right)
    float ly = isBull ? bottom : top
    l_style = isBull ? label.style_label_up : label.style_label_down
    label l = label.new(leftBar, ly, text=tag + " " + str.tostring(int(math.round(conf))) + "%", xloc=xloc.bar_index, style=l_style, color=bc, textcolor=color.white, size=size.small)
    [b, l]

// Remove the zone at index i (box, label, and all metadata) in lock-step.
removeZoneAt(int i) =>
    box.delete(array.get(boxArr, i))
    label.delete(array.get(labelArr, i))
    array.remove(boxArr, i)
    array.remove(labelArr, i)
    array.remove(zoneTop, i)
    array.remove(zoneBot, i)
    array.remove(zoneBull, i)

// Keep only the most recent max_zones zones on the chart (drop oldest).
pruneZones() =>
    while array.size(boxArr) > max_zones
        removeZoneAt(0)

// Mitigation: delete any zone that price has closed through (a broken level is
// no longer useful and is the main source of stale clutter). Iterate downward
// so index removals don't disturb not-yet-visited entries.
mitigateZones() =>
    int n = array.size(boxArr)
    if n > 0
        for i = n - 1 to 0
            float zt = array.get(zoneTop, i)
            float zb = array.get(zoneBot, i)
            bool zb_bull = array.get(zoneBull, i)
            bool broken = zb_bull ? close < zb : close > zt   // closed below support / above resistance
            if broken
                removeZoneAt(i)

// Deduplication: does the proposed price band overlap (within `pad`) any zone
// already on the chart? Prevents stacking many boxes at the same level.
f_overlaps(float top, float bottom, float pad) =>
    bool hit = false
    int n = array.size(zoneTop)
    if n > 0
        for i = 0 to n - 1
            float bt = array.get(zoneTop, i)
            float bb = array.get(zoneBot, i)
            if (bottom - pad) <= bt and (top + pad) >= bb   // interval intersection (+ pad)
                hit := true
                break
    hit

// Gated draw: clamps box height, then renders only if confidence clears the
// threshold AND it does not overlap an existing zone. Returns true when drawn.
f_drawZone(float top, float bottom, int leftBar, float conf, bool isBull, string tag, float pad, float maxH) =>
    bool ok = false
    float t = top
    float b = bottom
    // Clamp oversized boxes around their midpoint so a big displacement candle
    // doesn't paint a giant band across the chart.
    float h = t - b
    if maxH > 0 and h > maxH
        float mid = (t + b) / 2.0
        t := mid + maxH / 2.0
        b := mid - maxH / 2.0
    if not na(conf) and conf >= min_conf
        if not f_overlaps(t, b, pad)
            [bx, lb] = makeZone(t, b, leftBar, conf, isBull, tag)
            array.push(boxArr, bx)
            array.push(labelArr, lb)
            array.push(zoneTop, t)
            array.push(zoneBot, b)
            array.push(zoneBull, isBull)
            pruneZones()
            ok := true
    ok

// =============================================================
// === FEATURE EXTRACTION ===
// =============================================================
// Resolve the effective higher timeframe (auto-tailored or manual override).
htfRes = auto_htf ? f_autoHTF(htf_mult) : htf

atrVal = ta.atr(atr_len)
volAvg = ta.sma(volume, vol_len)

// Feature 1 — normalized volume (volume spike): ratio vs rolling average,
// capped at 3x and scaled into [0,1] so it is comparable to the other features.
volRatio = (not na(volAvg) and volAvg > 0) ? volume / volAvg : 1.0
f1 = math.min(volRatio / 3.0, 1.0)

// HTF OHLC pulled with a 1-bar offset + lookahead_off => only the last CLOSED
// HTF bar is ever used, which prevents repainting on the higher timeframe.
[htfO, htfH, htfL, htfC] = request.security(syminfo.tickerid, htfRes, [open[1], high[1], low[1], close[1]], lookahead=barmerge.lookahead_off)

// Feature 2 — HTF alignment: distance from price to the nearest HTF level,
// expressed in ATR units, then inverted (closer => higher) and scaled to [0,1].
float bigVal = 1e10
float dH = na(htfH) ? bigVal : math.abs(close - htfH)
float dL = na(htfL) ? bigVal : math.abs(close - htfL)
float dC = na(htfC) ? bigVal : math.abs(close - htfC)
float dO = na(htfO) ? bigVal : math.abs(close - htfO)
float nearest = math.min(math.min(dH, dL), math.min(dC, dO))
float distAtr = (not na(atrVal) and atrVal > 0 and nearest < bigVal) ? nearest / atrVal : na
f2 = na(distAtr) ? 0.5 : 1.0 - math.min(distAtr / 3.0, 1.0)

// Feature 3 — order-block / displacement strength: candle body size vs ATR,
// scaled to [0,1]. Large bodies precede order blocks / impulsive moves.
disp = (not na(atrVal) and atrVal > 0) ? math.abs(close - open) / atrVal : 0.0
f3 = math.min(disp / 3.0, 1.0)

// Pre-compute analysis series at top level (ta.* must run on every bar).
ph    = ta.pivothigh(high, pivot_len, pivot_len)
pl    = ta.pivotlow(low,  pivot_len, pivot_len)
volHi = ta.highest(volume, vol_peak_len)
tol   = (not na(atrVal) ? atrVal : 0.0) * zone_tolerance
pad   = (not na(atrVal) ? atrVal : 0.0) * merge_atr
maxH  = (not na(atrVal) ? atrVal : 0.0) * max_zone_atr

// Persisted last pivot levels for equal-high / equal-low comparison.
var float lastPH = na
var float lastPL = na

// HTF directional bias (from the last closed HTF bar).
htfBias = (na(htfC) or na(htfO)) ? "Neutral" : (htfC > htfO ? "Bullish" : (htfC < htfO ? "Bearish" : "Neutral"))

// =============================================================
// === KNN CLASSIFIER (training set maintenance + classification) ===
// =============================================================
// Everything below runs only on CONFIRMED (closed) bars. This both prevents
// repainting and stops duplicate objects from being created on intrabar ticks.
if barstate.isconfirmed
    // --- Mitigate broken zones first so freshly-drawn ones survive this bar ---
    if mitigate
        mitigateZones()

    // --- Build a labelled training sample for the bar `eval_window` bars ago ---
    // The outcome is now known (price has had eval_window bars to react), so the
    // label is non-repainting: high probability (1) if price travelled > N*ATR.
    if bar_index > eval_window + atr_len + vol_len
        float f1p       = f1[eval_window]
        float f2p       = f2[eval_window]
        float f3p       = f3[eval_window]
        float atrThen   = atrVal[eval_window]
        float priceThen = close[eval_window]
        if not na(f1p) and not na(f2p) and not na(f3p) and not na(atrThen) and atrThen > 0
            float futMove = math.abs(close - priceThen)
            float lbl = futMove > atrThen * eval_atr_mult ? 1.0 : 0.0
            array.push(trainF1, f1p)
            array.push(trainF2, f2p)
            array.push(trainF3, f3p)
            array.push(trainLabel, lbl)
            // Cap the training window to the `lookback` most recent samples.
            if array.size(trainF1) > lookback
                array.shift(trainF1)
                array.shift(trainF2)
                array.shift(trainF3)
                array.shift(trainLabel)

    // =========================================================
    // === ZONE DETECTION ===
    // =========================================================
    // Equal highs / equal lows: a fresh confirmed pivot within `tol` of the
    // previous pivot of the same kind (price revisiting the same level).
    bool eqHigh = false
    bool eqLow  = false
    if not na(ph)
        if not na(lastPH) and tol > 0 and math.abs(ph - lastPH) <= tol
            eqHigh := true
        lastPH := ph
    if not na(pl)
        if not na(lastPL) and tol > 0 and math.abs(pl - lastPL) <= tol
            eqLow := true
        lastPL := pl

    // Order blocks: a strong displacement candle (> ob_atr_mult * ATR body) whose
    // immediately-preceding candle is the opposite colour (the order block bar).
    bool strongUp   = (not na(atrVal)) and (close - open) > ob_atr_mult * atrVal
    bool strongDown = (not na(atrVal)) and (open - close) > ob_atr_mult * atrVal
    bool bullOB = strongUp   and close[1] < open[1]   // last down candle before up impulse
    bool bearOB = strongDown and close[1] > open[1]   // last up candle before down impulse

    // High-volume node: above the multiplier AND the local volume peak over a
    // wide window (vol_peak_len) so only genuine nodes qualify, not every spike.
    bool volNode = (not na(volAvg)) and (not na(volume)) and (not na(volHi)) and volume > volume_mult * volAvg and volume >= volHi

    // Classify once per bar (all same-bar zones share the current feature vector).
    // nz(...,50) gives a neutral score before the training set is warmed up, which
    // is below the default min_conf gate — so nothing is drawn until the model has
    // real history to vote on.
    bool anyZone = eqHigh or eqLow or bullOB or bearOB or volNode
    float conf = anyZone ? nz(knnConfidence(f1, f2, f3, knn_k), 50.0) : na

    // =========================================================
    // === VISUALIZATION ===
    // =========================================================
    // Cooldown: at most one new zone per `min_gap` bars. Combined with the
    // confidence gate, overlap dedup, height clamp and mitigation, this yields a
    // few clean, high-quality zones. Priority: OB > EQH/EQL > Volume.
    bool cooled = na(lastZoneBar) or (bar_index - lastZoneBar) >= min_gap
    if cooled
        bool placed = false
        if not placed and bullOB
            if f_drawZone(high[1], low[1], bar_index - 1, conf, true, "BULL OB", pad, maxH)
                lastZoneType := "Bullish OB"
                lastConf := conf
                lastZoneBar := bar_index
                placed := true
        if not placed and bearOB
            if f_drawZone(high[1], low[1], bar_index - 1, conf, false, "BEAR OB", pad, maxH)
                lastZoneType := "Bearish OB"
                lastConf := conf
                lastZoneBar := bar_index
                placed := true
        if not placed and eqHigh
            if f_drawZone(ph + tol / 2.0, ph - tol / 2.0, bar_index - pivot_len, conf, false, "EQH", pad, maxH)
                lastZoneType := "Equal Highs"
                lastConf := conf
                lastZoneBar := bar_index
                placed := true
        if not placed and eqLow
            if f_drawZone(pl + tol / 2.0, pl - tol / 2.0, bar_index - pivot_len, conf, true, "EQL", pad, maxH)
                lastZoneType := "Equal Lows"
                lastConf := conf
                lastZoneBar := bar_index
                placed := true
        if not placed and volNode
            bool vbull = close >= open
            if f_drawZone(high, low, bar_index, conf, vbull, "VOL", pad, maxH)
                lastZoneType := "High Volume Node"
                lastConf := conf
                lastZoneBar := bar_index
                placed := true

// =============================================================
// === DASHBOARD ===
// =============================================================
var table dash = na
if show_dashboard and barstate.islast
    if na(dash)
        dash := table.new(position.top_right, 2, 4, border_width=1, border_color=color.new(color.gray, 40), frame_width=1, frame_color=color.new(color.gray, 40))
    color confCol = na(lastConf) ? color.gray : (lastConf >= 70 ? color.green : (lastConf >= 40 ? color.orange : color.gray))
    color biasCol = htfBias == "Bullish" ? color.new(color.green, 0) : htfBias == "Bearish" ? color.new(color.red, 0) : color.new(color.gray, 0)
    // Title row (merged across both columns).
    table.cell(dash, 0, 0, "ML Liquidity Classifier", text_color=color.white, bgcolor=color.new(color.blue, 0), text_size=size.small)
    table.cell(dash, 1, 0, "", bgcolor=color.new(color.blue, 0))
    table.merge_cells(dash, 0, 0, 1, 0)
    // Metric rows.
    table.cell(dash, 0, 1, "Last Zone",  text_color=color.white, bgcolor=color.new(color.black, 10), text_size=size.small)
    table.cell(dash, 1, 1, lastZoneType, text_color=color.white, bgcolor=color.new(color.black, 10), text_size=size.small)
    table.cell(dash, 0, 2, "Confidence", text_color=color.white, bgcolor=color.new(color.black, 10), text_size=size.small)
    table.cell(dash, 1, 2, na(lastConf) ? "n/a" : str.tostring(int(math.round(lastConf))) + "%", text_color=color.white, bgcolor=color.new(confCol, 25), text_size=size.small)
    table.cell(dash, 0, 3, "HTF Bias",   text_color=color.white, bgcolor=color.new(color.black, 10), text_size=size.small)
    table.cell(dash, 1, 3, htfBias + " (" + htfRes + ")", text_color=color.white, bgcolor=biasCol, text_size=size.small)
