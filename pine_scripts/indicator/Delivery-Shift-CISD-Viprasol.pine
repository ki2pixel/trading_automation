// This Pine Script™ v6 indicator is subject to the terms of the Mozilla Public License 2.0
// https://mozilla.org/MPL/2.0/
// (c) Viprasol
//
// Based on an open-source "Change in State of Delivery (CISD)" community indicator.
// Original components credited in the publication description.

//@version=6
indicator(
    title            = "[Viprasol] CISD Delivery Shift",
    shorttitle       = "VP - CISD",
    overlay          = true,
    max_lines_count  = 500,
    max_labels_count = 500,
    behind_chart     = false
)

// ══════════════════════════════════════════════════════════════
// Constants — Viprasol Visual Identity
// ══════════════════════════════════════════════════════════════

const color BULL_SIGNATURE  = #00ffaa
const color BEAR_SIGNATURE  = #ff3d71
const color PANEL_BG         = #111725
const color PANEL_HEADER     = #18233a
const color PANEL_BORDER     = #000000
const color PANEL_TEXT       = #e6e9f0
const color PANEL_MUTED      = #8a93a6
const color TP_LABEL_COL     = #22c55e
const color ENTRY_LABEL_COL  = #00bcd4
const color SL_LABEL_COL     = #ef4444

// Performance guards — bound the CISD scan loops so a single bar cannot run away
const int MAX_LEG       = 500    // max bars walked back when measuring a CISD leg
const int MAX_POTENTIAL = 60     // max stored candidate origins (pairs of open + bar_index)

// ══════════════════════════════════════════════════════════════
// Inputs
// ══════════════════════════════════════════════════════════════

string GRP_CALC    = "Calculations"
string GRP_FILTERS = "Signal Filters (Viprasol)"
string GRP_QUALITY = "Confluence & Quality (Viprasol)"
string GRP_RISK    = "Risk Overlay (Viprasol)"
string GRP_APPEAR  = "Appearance"
string GRP_DASH    = "Dashboard / Display"

// — Core calculation (from original)
noiseFilterInput       = input.float(0.7, "Noise Filter", group = GRP_CALC, maxval = 1, minval = 0, step = 0.1,
     tooltip = "Displacement ratio a leg must exceed to qualify as a CISD trigger. Larger = less noise.")
swingPeriodInput       = input.int(12, "Swing Period", group = GRP_CALC,
     tooltip = "Pivot period for swing-point / liquidity detection. Larger = longer-term swings.")
expiryBarsInput        = input.int(100, "Expiry Bars", group = GRP_CALC,
     tooltip = "Bars after which old liquidity lines stop updating / expire.")
liquidityLookbackInput = input.int(10, "Liquidity Lookback", group = GRP_CALC,
     tooltip = "Lookback to check whether opposing liquidity was swept just before a CISD.")

// — Signal filters (Viprasol additions; defaults preserve original behaviour)
cooldownInput     = input.int(0, "Signal Cooldown (bars)", minval = 0, maxval = 200, group = GRP_FILTERS,
     tooltip = "Minimum bars between qualified CISD signals. 0 = disabled (original behaviour).")
useVolFilterInput = input.bool(false, "Require Volume Surge", group = GRP_FILTERS,
     tooltip = "Qualified signals require above-average volume on the CISD bar.")
volLenInput       = input.int(20, "Volume Avg Length", minval = 2, maxval = 200, group = GRP_FILTERS, active = useVolFilterInput)
volMultInput      = input.float(1.5, "Volume Surge Multiplier", minval = 1.0, maxval = 5.0, step = 0.1, group = GRP_FILTERS, active = useVolFilterInput)
useHtfInput       = input.bool(false, "Require HTF EMA Bias", group = GRP_FILTERS,
     tooltip = "Qualified bull signals only above, bear only below, the higher-timeframe EMA.")
htfResInput       = input.timeframe("240", "HTF Resolution", group = GRP_FILTERS, active = useHtfInput)
htfEmaLenInput    = input.int(50, "HTF EMA Length", minval = 5, maxval = 400, group = GRP_FILTERS, active = useHtfInput)

// — Confluence & quality (Viprasol additions)
showGradeInput = input.bool(true, "Show Quality Grade on CISD", group = GRP_QUALITY,
     tooltip = "Label each CISD A (>=3) / B (2) / C (<=1) from its confluence score (displacement, sweep, HTF, volume).")
minScoreInput  = input.int(0, "Minimum Confluence Score (0-4)", minval = 0, maxval = 4, group = GRP_QUALITY,
     tooltip = "Qualified signals must reach at least this confluence score. 0 = all CISDs qualify.")

// — Risk overlay (Viprasol additions)
showLevelsInput      = input.bool(true, "Show SL/TP on Qualified CISD", group = GRP_RISK)
showPriceLabelsInput = input.bool(true, "Show Price Labels (TP/Entry/SL)", group = GRP_RISK, active = showLevelsInput,
     tooltip = "Colored Entry / SL / TP price tags at the projection line ends.")
atrPeriodInput       = input.int(14, "ATR Period (SL buffer)", minval = 2, maxval = 100, group = GRP_RISK)
slBufferAtrInput     = input.float(0.5, "SL ATR Buffer", minval = 0.0, maxval = 5.0, step = 0.1, group = GRP_RISK,
     tooltip = "Extra ATR distance placed beyond the CISD swing extreme for the stop.")
rrRatioInput         = input.float(2.0, "Risk : Reward", minval = 0.5, maxval = 10.0, step = 0.1, group = GRP_RISK)

// — Appearance (from original)
bullColorInput     = input.color(BULL_SIGNATURE, "Bullish Colour", group = GRP_APPEAR, tooltip = "Bullish visuals and positive sentiment.")
bearColorInput     = input.color(BEAR_SIGNATURE, "Bearish Colour", group = GRP_APPEAR, tooltip = "Bearish visuals and negative sentiment.")
bodyTranspInput    = input.int(90, "Candle Body Transparency", maxval = 100, minval = 0, group = GRP_APPEAR)
wickTranspInput    = input.int(40, "Candle Wick/Border Transparency", maxval = 100, minval = 0, group = GRP_APPEAR)
hideExpiredInput   = input.bool(true, "Hide Expired Levels", group = GRP_APPEAR, tooltip = "Delete liquidity levels once they exceed the expiry threshold.")
hideMitigatedInput = input.bool(false, "Hide Mitigated Levels", group = GRP_APPEAR, tooltip = "Delete liquidity levels as soon as price mitigates them.")

// — Dashboard
showTableInput = input.bool(true, "Show Info Dashboard", group = GRP_DASH)
dashPosInput   = input.string("Top Right", "Dashboard Position", options = ["Top Right", "Top Left", "Bottom Right", "Bottom Left"], group = GRP_DASH)

// ══════════════════════════════════════════════════════════════
// Functions
// ══════════════════════════════════════════════════════════════

gradeOf(int score) =>
    score >= 3 ? "A" : score == 2 ? "B" : "C"

// ══════════════════════════════════════════════════════════════
// Calculations — Swing liquidity lines  [from original]
// ══════════════════════════════════════════════════════════════

float pivotHigh = ta.pivothigh(swingPeriodInput, swingPeriodInput)
float pivotLow  = ta.pivotlow(swingPeriodInput, swingPeriodInput)

var array<line> swingHighLines = array.new_line()
var array<line> swingLowLines  = array.new_line()

if not na(pivotHigh)
    swingHighLines.unshift(line.new(bar_index - swingPeriodInput, high[swingPeriodInput], bar_index, high[swingPeriodInput], color = color.new(chart.fg_color, 50)))
if not na(pivotLow)
    swingLowLines.unshift(line.new(bar_index - swingPeriodInput, low[swingPeriodInput], bar_index, low[swingPeriodInput], color = color.new(chart.fg_color, 50)))

var float lastWickedHigh = na
var float lastWickedLow  = na

bool wickedHigh = false
bool wickedLow  = false

// Extend / mitigate / expire swing-high liquidity
if swingHighLines.size() > 0
    for i = swingHighLines.size() - 1 to 0
        if i < swingHighLines.size()
            line l = swingHighLines.get(i)
            if bar_index - line.get_x1(l) < expiryBarsInput
                float lvl = line.get_y1(l)
                line.set_x2(l, bar_index)
                if high >= lvl and barstate.isconfirmed
                    if hideMitigatedInput
                        line.delete(l)
                    swingHighLines.remove(i)
                    wickedHigh := true
                    lastWickedHigh := lvl
            else
                if hideExpiredInput
                    line.delete(l)
                    swingHighLines.remove(i)

// Extend / mitigate / expire swing-low liquidity
if swingLowLines.size() > 0
    for i = swingLowLines.size() - 1 to 0
        if i < swingLowLines.size()
            line l = swingLowLines.get(i)
            if bar_index - line.get_x1(l) < expiryBarsInput
                float lvl = line.get_y1(l)
                line.set_x2(l, bar_index)
                if low <= lvl and barstate.isconfirmed
                    if hideMitigatedInput
                        line.delete(l)
                    swingLowLines.remove(i)
                    wickedLow := true
                    lastWickedLow := lvl
            else
                if hideExpiredInput
                    line.delete(l)
                    swingLowLines.remove(i)

while swingHighLines.size() > 100
    line.delete(swingHighLines.pop())
while swingLowLines.size() > 100
    line.delete(swingLowLines.pop())

int barsSinceHigh = ta.barssince(wickedHigh)
int barsSinceLow  = ta.barssince(wickedLow)

// ══════════════════════════════════════════════════════════════
// Calculations — CISD detection  [from original]
// ══════════════════════════════════════════════════════════════

var float potentialBullLevel = 0.0   // retained from original (declared but unused)
var float potentialBearLevel = 0.0
var float originOpen = 0.0
var float originClose = 0.0

var array<float> bearPotential = array.new_float()
var array<float> bullPotential = array.new_float()

// A bullish-to-bearish candle flip seeds a potential bearish CISD
if close[1] < open[1] and close > open
    bearPotential.unshift(bar_index)
    bearPotential.unshift(open)

// A bearish-to-bullish candle flip seeds a potential bullish CISD
if close[1] > open[1] and close < open
    bullPotential.unshift(bar_index)
    bullPotential.unshift(open)

// Cap candidate lists so they cannot grow unbounded (oldest pair dropped)  [new — perf guard]
while bearPotential.size() > MAX_POTENTIAL
    bearPotential.pop()
    bearPotential.pop()
while bullPotential.size() > MAX_POTENTIAL
    bullPotential.pop()
    bullPotential.pop()

int   cisdState  = 0
float originLevel = 0.0
float originIndex = 0.0

// Captured for grading / risk overlay  [new]
float capturedRatio   = na
float capturedExtreme = na

// Bearish CISD scan
if bearPotential.size() > 0
    bool scanning = true
    int scanGuard = 0
    while scanning and scanGuard <= MAX_POTENTIAL
        scanGuard += 1
        if close < bearPotential.first()
            int legLen = math.max(0, math.min(int(bar_index - bearPotential.get(1)), MAX_LEG))
            float highestClose = 0.0
            for i = 0 to legLen
                if close[i] > highestClose
                    highestClose := close[i]
            bool walking = true
            int walkIdx = math.max(1, int(bar_index - bearPotential.get(1) + 1))
            int walkGuard = 0
            float legTop = 0.0
            while walking and walkGuard < MAX_LEG
                walkGuard += 1
                if close[walkIdx] < open[walkIdx]
                    legTop := open[walkIdx]
                    walkIdx += 1
                else
                    walking := false
            float ratioVal = (highestClose - bearPotential.first()) / (legTop - bearPotential.first())
            if ratioVal > noiseFilterInput
                originLevel := bearPotential.first()
                originIndex := bearPotential.get(1)
                capturedRatio := ratioVal
                capturedExtreme := highestClose
                bearPotential.clear()
                cisdState := 1
                scanning := false
            else
                bearPotential.shift()
                bearPotential.shift()
                if bearPotential.size() == 0
                    scanning := false
        else
            scanning := false

// Bullish CISD scan
if bullPotential.size() > 0
    bool scanning = true
    int scanGuard = 0
    while scanning and scanGuard <= MAX_POTENTIAL
        scanGuard += 1
        if close > bullPotential.first()
            int legLen = math.max(0, math.min(int(bar_index - bullPotential.get(1)), MAX_LEG))
            float lowestClose = close
            for i = 0 to legLen
                if close[i] < lowestClose
                    lowestClose := close[i]
            bool walking = true
            int walkIdx = math.max(1, int(bar_index - bullPotential.get(1) + 1))
            int walkGuard = 0
            float legBottom = 0.0
            while walking and walkGuard < MAX_LEG
                walkGuard += 1
                if close[walkIdx] > open[walkIdx]
                    legBottom := open[walkIdx]
                    walkIdx += 1
                else
                    walking := false
            float ratioVal = (bullPotential.first() - lowestClose) / (bullPotential.first() - legBottom)
            if ratioVal > noiseFilterInput
                originLevel := bullPotential.first()
                originIndex := bullPotential.get(1)
                capturedRatio := ratioVal
                capturedExtreme := lowestClose
                bullPotential.clear()
                cisdState := 2
                scanning := false
            else
                bullPotential.shift()
                bullPotential.shift()
                if bullPotential.size() == 0
                    scanning := false

// ══════════════════════════════════════════════════════════════
// Calculations — Trend, liquidity sweep, HTF, volume  [original + new]
// ══════════════════════════════════════════════════════════════

var int trendState = 0
bool bearishSweep = false
bool bullishSweep = false

if cisdState == 1
    trendState := -1
    line.new(int(originIndex), originLevel, bar_index, originLevel, color = bearColorInput, width = 3)
    if barsSinceHigh <= liquidityLookbackInput and close < lastWickedHigh
        bearishSweep := true

if cisdState == 2
    trendState := 1
    line.new(int(originIndex), originLevel, bar_index, originLevel, color = bullColorInput, width = 3)
    if barsSinceLow <= liquidityLookbackInput and close > lastWickedLow
        bullishSweep := true

// [new] HTF EMA bias (computed always so the grade reflects HTF regardless of the filter toggle)
float htfEma     = nz(request.security(syminfo.tickerid, htfResInput, ta.ema(close, htfEmaLenInput), lookahead = barmerge.lookahead_off), close)
bool  htfBullRaw = close > htfEma
bool  htfBearRaw = close < htfEma

// [new] volume surge
float volAvg   = ta.sma(volume, volLenInput)
bool  volSurge = volume > volAvg * volMultInput

float atrVal = ta.atr(atrPeriodInput)

// ══════════════════════════════════════════════════════════════
// Calculations — Confluence score & qualified signals  [new — Viprasol]
// ══════════════════════════════════════════════════════════════

bool cisdFired   = cisdState != 0
bool dispStrong  = not na(capturedRatio) and capturedRatio >= noiseFilterInput + (1 - noiseFilterInput) * 0.5
bool sweepNow    = bearishSweep or bullishSweep
bool htfAlignNow = cisdState == 2 ? htfBullRaw : cisdState == 1 ? htfBearRaw : false
int  cisdScore   = (dispStrong ? 1 : 0) + (sweepNow ? 1 : 0) + (htfAlignNow ? 1 : 0) + (volSurge ? 1 : 0)

bool volOk     = not useVolFilterInput or volSurge
bool htfBullOk = not useHtfInput or htfBullRaw
bool htfBearOk = not useHtfInput or htfBearRaw
var int lastCisdBar = -100000
bool coolOk    = cooldownInput == 0 or (bar_index - lastCisdBar) >= cooldownInput
bool scoreOk   = cisdScore >= minScoreInput

bool qualifiedBull = cisdState == 2 and volOk and htfBullOk and coolOk and scoreOk
bool qualifiedBear = cisdState == 1 and volOk and htfBearOk and coolOk and scoreOk
if qualifiedBull or qualifiedBear
    lastCisdBar := bar_index

// ══════════════════════════════════════════════════════════════
// Visuals — original sweep shapes, swing dots, gradient candles
// ══════════════════════════════════════════════════════════════

plotshape(bearishSweep ? high : na, "Bearish CISD with Liquidity Sweep", shape.labeldown, location.abovebar, bearColorInput, size = size.small, text = "▼", textcolor = chart.fg_color)
plotshape(bullishSweep ? low  : na, "Bullish CISD with Liquidity Sweep", shape.labelup,   location.belowbar, bullColorInput, size = size.small, text = "▲", textcolor = chart.fg_color)

plotchar(not na(pivotHigh) ? high[swingPeriodInput] : na, "Swing High", "●", location.absolute, bearColorInput, size = size.tiny, offset = -swingPeriodInput)
plotchar(not na(pivotLow)  ? low[swingPeriodInput]  : na, "Swing Low",  "●", location.absolute, bullColorInput, size = size.tiny, offset = -swingPeriodInput)

color candleBody   = color.from_gradient(bodyTranspInput, 0, 100, trendState > 0 ? bullColorInput : bearColorInput, chart.bg_color)
color candleBorder = color.from_gradient(wickTranspInput, 0, 100, trendState > 0 ? bullColorInput : bearColorInput, chart.bg_color)
plotcandle(open, high, low, close, "Price Candles", candleBody, candleBorder, bordercolor = candleBorder)

// ══════════════════════════════════════════════════════════════
// Visuals — Quality grade label  [new]
// ══════════════════════════════════════════════════════════════

if cisdFired and showGradeInput
    color gradeCol = cisdState == 2 ? bullColorInput : bearColorInput
    label.new(bar_index, originLevel, gradeOf(cisdScore) + " " + str.tostring(cisdScore) + "/4",
         style = cisdState == 2 ? label.style_label_up : label.style_label_down,
         color = color.new(gradeCol, 20), textcolor = color.white, size = size.small)

// ══════════════════════════════════════════════════════════════
// Visuals — Risk overlay on qualified CISD  [new]
// ══════════════════════════════════════════════════════════════

var line  enLine = na
var line  slLine = na
var line  tpLine = na
var label enLbl  = na
var label slLbl  = na
var label tpLbl  = na

if (qualifiedBull or qualifiedBear) and showLevelsInput and not na(capturedExtreme)
    float entry = originLevel
    float sl    = qualifiedBull ? capturedExtreme - atrVal * slBufferAtrInput : capturedExtreme + atrVal * slBufferAtrInput
    float risk  = math.abs(entry - sl)
    float tp    = qualifiedBull ? entry + risk * rrRatioInput : entry - risk * rrRatioInput
    int x2 = bar_index + 16
    line.delete(enLine)
    line.delete(slLine)
    line.delete(tpLine)
    label.delete(enLbl)
    label.delete(slLbl)
    label.delete(tpLbl)
    enLine := line.new(bar_index, entry, x2, entry, color = color.new(ENTRY_LABEL_COL, 10), width = 1)
    slLine := line.new(bar_index, sl,    x2, sl,    color = color.new(SL_LABEL_COL, 10), width = 1, style = line.style_dashed)
    tpLine := line.new(bar_index, tp,    x2, tp,    color = color.new(TP_LABEL_COL, 10), width = 1, style = line.style_dashed)
    if showPriceLabelsInput
        enLbl := label.new(x2, entry, "ENTRY " + str.tostring(entry, format.mintick), style = label.style_label_left, color = ENTRY_LABEL_COL, textcolor = color.white, size = size.small)
        slLbl := label.new(x2, sl,    "SL "    + str.tostring(sl,    format.mintick), style = label.style_label_left, color = SL_LABEL_COL,    textcolor = color.white, size = size.small)
        tpLbl := label.new(x2, tp,    "TP "    + str.tostring(tp,    format.mintick), style = label.style_label_left, color = TP_LABEL_COL,    textcolor = color.white, size = size.small)

// ══════════════════════════════════════════════════════════════
// Visuals — Info Dashboard
// ══════════════════════════════════════════════════════════════

dashPos = switch dashPosInput
    "Top Left"     => position.top_left
    "Bottom Right" => position.bottom_right
    "Bottom Left"  => position.bottom_left
    => position.top_right

var table tbl = table.new(dashPos, 2, 8, bgcolor = PANEL_BG, border_color = PANEL_BORDER, border_width = 1, frame_color = PANEL_BORDER, frame_width = 1)

if barstate.islast and showTableInput
    string trendTxt = trendState > 0 ? "▲ Bullish" : trendState < 0 ? "▼ Bearish" : "— Neutral"
    color  trendCol = trendState > 0 ? bullColorInput : trendState < 0 ? bearColorInput : PANEL_MUTED
    string htfTxt   = useHtfInput ? (htfBullRaw ? "▲ Bull" : "▼ Bear") : "Off"

    table.cell(tbl, 0, 0, "VP — CISD Delivery Shift", text_color = PANEL_TEXT, text_size = size.small, bgcolor = PANEL_HEADER)
    table.cell(tbl, 1, 0, "● Live", text_color = BULL_SIGNATURE, text_size = size.small, bgcolor = PANEL_HEADER)

    table.cell(tbl, 0, 1, "Delivery State", text_color = PANEL_TEXT, text_size = size.small)
    table.cell(tbl, 1, 1, trendTxt, text_color = trendCol, text_size = size.small)

    table.cell(tbl, 0, 2, "Last CISD Grade", text_color = PANEL_TEXT, text_size = size.small)
    table.cell(tbl, 1, 2, cisdFired ? gradeOf(cisdScore) + " (" + str.tostring(cisdScore) + "/4)" : "—", text_color = PANEL_TEXT, text_size = size.small)

    table.cell(tbl, 0, 3, "Liquidity Sweep", text_color = PANEL_TEXT, text_size = size.small)
    table.cell(tbl, 1, 3, sweepNow ? "✓ Yes" : "— No", text_color = sweepNow ? BULL_SIGNATURE : PANEL_MUTED, text_size = size.small)

    table.cell(tbl, 0, 4, "HTF Bias", text_color = PANEL_TEXT, text_size = size.small)
    table.cell(tbl, 1, 4, htfTxt, text_color = useHtfInput ? (htfBullRaw ? bullColorInput : bearColorInput) : PANEL_MUTED, text_size = size.small)

    table.cell(tbl, 0, 5, "Vol Surge", text_color = PANEL_TEXT, text_size = size.small)
    table.cell(tbl, 1, 5, volSurge ? "✓ Yes" : "— No", text_color = volSurge ? BULL_SIGNATURE : PANEL_MUTED, text_size = size.small)

    table.cell(tbl, 0, 6, "Live Liquidity", text_color = PANEL_TEXT, text_size = size.small)
    table.cell(tbl, 1, 6, str.tostring(swingHighLines.size()) + "H / " + str.tostring(swingLowLines.size()) + "L", text_color = PANEL_MUTED, text_size = size.small)

    table.cell(tbl, 0, 7, "Grade", text_color = PANEL_MUTED, text_size = size.tiny)
    table.cell(tbl, 1, 7, "A>=3 B=2 C<=1", text_color = PANEL_MUTED, text_size = size.tiny)

// ══════════════════════════════════════════════════════════════
// Alerts — dynamic messages with {{ticker}} {{close}} {{interval}}
// ══════════════════════════════════════════════════════════════

alertcondition(wickedHigh, "VP CISD Swing High Mitigation", "[Viprasol] CISD: swing-high liquidity mitigated on {{ticker}} ({{interval}}) at {{close}}")
alertcondition(wickedLow,  "VP CISD Swing Low Mitigation",  "[Viprasol] CISD: swing-low liquidity mitigated on {{ticker}} ({{interval}}) at {{close}}")
alertcondition(cisdState == 1, "VP CISD Bearish", "[Viprasol] CISD: bearish change in state of delivery on {{ticker}} ({{interval}}) at {{close}}")
alertcondition(cisdState == 2, "VP CISD Bullish", "[Viprasol] CISD: bullish change in state of delivery on {{ticker}} ({{interval}}) at {{close}}")
alertcondition(bearishSweep, "VP CISD Strong Bearish (Sweep)", "[Viprasol] CISD: strong bearish CISD with liquidity sweep on {{ticker}} ({{interval}}) at {{close}}")
alertcondition(bullishSweep, "VP CISD Strong Bullish (Sweep)", "[Viprasol] CISD: strong bullish CISD with liquidity sweep on {{ticker}} ({{interval}}) at {{close}}")
alertcondition(qualifiedBull, "VP CISD Qualified Bull", "[Viprasol] CISD: qualified BULL signal (filters + score passed) on {{ticker}} ({{interval}}) at {{close}}")
alertcondition(qualifiedBear, "VP CISD Qualified Bear", "[Viprasol] CISD: qualified BEAR signal (filters + score passed) on {{ticker}} ({{interval}}) at {{close}}")
