int numberObShow     = input.int(1, 'عدد مناطق العرض والطلب', minval=1, maxval=10, group = settings_tools)
color bearishOrderblockColor = input.color(color.new(#f36767, 54), title='لون منطقة العرض', group = settings_tools)
color bullishOrderblockColor = input.color(color.new(#a8f373, 61), title='لون منطقة الطلب', group = settings_tools)
