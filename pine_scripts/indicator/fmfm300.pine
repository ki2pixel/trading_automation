//@version=6
indicator("fmfm300 ", overlay=true, max_lines_count=500, max_bars_back=5000, max_boxes_count=500, max_labels_count=500)

atrPeriod   = input.int(10, "ATR Period", minval=1, group="⚙️ Supertrend")
factor      = input.float(3.0, "Factor", minval=0.1, step=0.1, group="⚙️ Supertrend")
ema20Length = input.int(20, "EMA 20 Length", minval=1, group="⚙️ Supertrend")

maType            = input.string("EMA", "نوع المتوسط", options=["EMA", "SMA"], group="⚙️ Braid Filter")
Period1           = input.int(3,  "الفترة الأولى",  group="⚙️ Braid Filter")
Period2           = input.int(7,  "الفترة الثانية", group="⚙️ Braid Filter")
Period3           = input.int(14, "الفترة الثالثة", group="⚙️ Braid Filter")
PipsMinSepPercent = input.int(40, "الحد الأدنى للفصل % (حسب ATR)", group="⚙️ Braid Filter")

lookBack   = input.int(100, "Calculated Bars", group="⚙️ HeatMap")
displPf    = input.bool(true, "Profile", group="⚙️ HeatMap")
bins       = input.int(50, "Resolution", group="⚙️ HeatMap")
resolution = 100
color sellColor = input.color(color.blue, "Sell Liquidity", group="⚙️ HeatMap")
color buyColor  = input.color(color.lime, "Buy Liquidity",  group="⚙️ HeatMap")
bool  poc       = input.bool(true, "", inline="maxp", group="⚙️ HeatMap")
color maxColor  = input.color(color.orange, "Max Point Liquidity", inline="maxp", group="⚙️ HeatMap")

pvtLength = input.int(20, "Pivot Length", minval=1, group="⚙️ Pivot")

// ========== إعدادات المؤشر الثاني ==========
sdLength2  = input.int(14, "طول Supply/Demand", group="⚙️ مؤشر ثاني")
rsi2Upper  = input.int(55, "حد RSI أعلى", minval=1, maxval=100, group="⚙️ مؤشر ثاني")
rsi2Lower  = input.int(45, "حد RSI أدنى", minval=1, maxval=100, group="⚙️ مؤشر ثاني")
tblSize2   = input.string("Normal", "حجم النص",
             options=["Tiny", "Small", "Normal", "Large"],
             group="⚙️ مؤشر ثاني")

getSize(s) =>
    s == "Tiny" ? size.tiny : s == "Small" ? size.small : s == "Normal" ? size.normal : size.large

tSize2 = getSize(tblSize2)

formatBigNum(val) =>
    if val >= 1000000000
        str.tostring(val / 1000000000, "#.##") + "B"
    else if val >= 1000000
        str.tostring(val / 1000000, "#.##") + "M"
    else if val >= 1000
        str.tostring(val / 1000, "#.##") + "K"
    else
        str.tostring(val, "#")

// ========== حسابات المؤشر الثاني ==========
demandPressure2 = close > open ? (close - open) * volume : 0.0
supplyPressure2 = close < open ? (open - close) * volume : 0.0
avgDemand2      = ta.sma(demandPressure2, sdLength2)
avgSupply2      = ta.sma(supplyPressure2, sdLength2)
totalPressure2  = avgDemand2 + avgSupply2
demandPerc2     = totalPressure2 > 0 ? (avgDemand2 / totalPressure2) * 100 : 50.0
supplyPerc2     = totalPressure2 > 0 ? (avgSupply2 / totalPressure2) * 100 : 50.0
rsi2            = ta.rsi(close, 14)
flowText        = close > open ? "🟢" : close < open ? "🔴" : "⚪"

// ========== Supertrend ==========
[supertrend, direction] = ta.supertrend(factor, atrPeriod)
bull  = direction < 0
ema20 = ta.ema(close, ema20Length)

// ========== Braid Filter ==========
ma(type, src_ma, len) => type == "SMA" ? ta.sma(src_ma, len) : ta.ema(src_ma, len)
ma1 = ma(maType, close, Period1)
ma2 = ma(maType, open,  Period2)
ma3 = ma(maType, close, Period3)

dif    = math.max(math.max(ma1,ma2),ma3) - math.min(math.min(ma1,ma2),ma3)
filter = ta.atr(14) * PipsMinSepPercent / 100

BraidColor = ma1 > ma2 and dif > filter ? color.green :
             ma2 > ma1 and dif > filter ? color.red : color.gray

isCall     = BraidColor == color.green
isPut      = BraidColor == color.red
isSideways = not isCall and not isPut

combinedText  = bull and isCall ? "صاعد" : not bull and isPut ? "هابط" : not bull and isSideways ? "عرضي هابط" : bull and isSideways ? "عرضي صاعد" : "انتبه"
combinedColor = bull and isCall ? color.new(color.green, 40) : not bull and isPut ? color.new(color.red, 40) : not bull and isSideways ? color.new(color.red, 60) : bull and isSideways ? color.new(color.green, 60) : color.new(color.yellow, 40)


plot(ema20, "EMA 20", color=color.blue, linewidth=1)

var label bullLabel = na
var label bearLabel = na

if bull and not bull[1]
    if not na(bearLabel)
        label.delete(bearLabel)
    bullLabel := label.new(bar_index, supertrend, "إيجابي",
                           style=label.style_label_up,
                           color=color.new(color.green, 80),
                           textcolor=color.green,
                           size=size.normal)

if not bull and bull[1]
    if not na(bullLabel)
        label.delete(bullLabel)
    bearLabel := label.new(bar_index, supertrend, "سلبي",
                           style=label.style_label_down,
                           color=color.new(color.red, 80),
                           textcolor=color.red,
                           size=size.normal)

noColor  = #00000000
pvtHigh = ta.pivothigh(pvtLength, pvtLength)
pvtLow  = ta.pivotlow(pvtLength, pvtLength)

var label lastHigh     = na
var label lastLow      = na
var label lastHighTemp = na
var label lastLowTemp  = na

pvtLengthTemp = 3
pvtHighTemp   = ta.pivothigh(pvtLengthTemp, pvtLengthTemp)
pvtLowTemp    = ta.pivotlow(pvtLengthTemp, pvtLengthTemp)

var float pvtHigh1Temp = 0.
var float pvtLow1Temp  = 0.

if not na(pvtHigh)
    label.delete(lastHigh)
    label.delete(lastHighTemp)
    lastHigh := label.new(bar_index[pvtLength], pvtHigh, "▼", xloc.bar_index, yloc.price, noColor, label.style_label_down, #e8bcbc, size.normal, text.align_center, "Pivot High · " + str.tostring(pvtHigh, format.mintick))

if not na(pvtLow)
    label.delete(lastLow)
    label.delete(lastLowTemp)
    lastLow := label.new(bar_index[pvtLength], pvtLow, "▲", xloc.bar_index, yloc.price, noColor, label.style_label_up, #b3c9f5, size.normal, text.align_center, "Pivot Low · " + str.tostring(pvtLow, format.mintick))

if not na(pvtHighTemp)
    if pvtHighTemp > pvtHigh1Temp
        label.delete(lastHighTemp)
        lastHighTemp := label.new(bar_index[pvtLengthTemp], pvtHighTemp, "●\n▼", xloc.bar_index, yloc.price, noColor, label.style_label_down, #284aa9, size.normal, text.align_center, "Temporary Pivot High · " + str.tostring(pvtHighTemp, format.mintick) + "\n⚠ Subject to repaint")
    pvtHigh1Temp := pvtHighTemp

if high > pvtHigh1Temp
    label.delete(lastHighTemp)

if not na(pvtLowTemp)
    if pvtLowTemp < pvtLow1Temp
        label.delete(lastLowTemp)
        lastLowTemp := label.new(bar_index[pvtLengthTemp], pvtLowTemp, "▲\n●", xloc.bar_index, yloc.price, noColor, label.style_label_up, #284aa9, size.normal, text.align_center, "Temporary Pivot Low · " + str.tostring(pvtLowTemp, format.mintick) + "\n⚠ Subject to repaint")
    pvtLow1Temp := pvtLowTemp

if low < pvtLow1Temp
    label.delete(lastLowTemp)

var boxes2      = array.new<box>()
var labels2     = array.new<label>()
var lines2      = array.new<line>()
var volume_bins = array.new<float>(bins, 0.)
h_l             = array.new<float>()

type pivot
    float value
    int   index
    float volume_
    float vol
    bool  isLower

var pivots = array.new<pivot>()

h2 = ta.highest(2)
l2 = ta.lowest(2)

volumeArr = array.new_float(lookBack)
vol2      = math.sum(volume, 10)

for i = 0 to lookBack-1
    volumeArr.set(i, vol2[i])

nVol   = vol2 / volumeArr.max() * 100
atr2   = ta.atr(5) / 50
offset = ta.highest(atr2 * nVol, lookBack)

for i = 0 to lookBack-1
    h_l.push(high[i]+offset[i])
    h_l.push(low[i]-offset[i])

if last_bar_index - bar_index < lookBack
    top    = h_l.max()
    bot    = h_l.min()
    step2  = (top-bot)/resolution
    level1 = high + atr2 * nVol
    level2 = low  - atr2 * nVol

    if h2 == high
        for i = 0 to resolution - 1
            lower = bot + step2 * i
            mid   = lower + step2/2
            if math.abs(level1 - mid) <= step2
                pivots.push(pivot.new(mid, bar_index, nVol, vol2, false))

    if l2 == low
        for i = 0 to resolution - 1
            lower = bot + step2 * i
            mid   = lower + step2/2
            if math.abs(level2 - mid) <= step2
                pivots.push(pivot.new(mid - atr2 * nVol, bar_index, nVol, vol2, true))

    if pivots.size() > 0
        for p in pivots
            y     = p.value
            isLow = p.isLower
            if isLow and low < y
                pivots.remove(pivots.indexof(p))
            if not isLow and high > y
                pivots.remove(pivots.indexof(p))

var float sMin = 100.0
var float sMax = 15000000000.0

var float pocVol      = 0.0
var float maxBuyVol2  = 0.0
var float maxSellVol2 = 0.0

if barstate.islast

    if lines2.size() > 0
        for ln in lines2
            ln.delete()

    for b in boxes2
        b.delete()
    boxes2.clear()

    for lbl in labels2
        lbl.delete()
    labels2.clear()

    step3 = (h_l.max() - h_l.min()) / bins

    for j = 0 to bins-1
        volume_bins.set(j, 0)

    if pivots.size() > 0
        for i = 0 to pivots.size() - 1
            lvl    = pivots.get(i)
            vol_   = lvl.vol
            line_y = lvl.value
            for j = 0 to bins-1
                lower = h_l.min() + step3 * j
                mid   = lower + step3/2
                upper = lower + step3
                if math.abs(line_y-mid) < step3
                    volume_bins.set(j, volume_bins.get(j) + vol_)

        maxBuyVol2  := 0.0
        maxSellVol2 := 0.0
        maxBuyIdx   = -1
        maxSellIdx  = -1

        for j = 0 to bins-1
            lower = h_l.min() + step3 * j
            mid   = lower + step3/2
            voll  = volume_bins.get(j)
            if close > mid
                if voll > maxBuyVol2
                    maxBuyVol2 := voll
                    maxBuyIdx  := j
            else
                if voll > maxSellVol2
                    maxSellVol2 := voll
                    maxSellIdx  := j

        pocVol := volume_bins.max()

        for j = 0 to bins-1
            lower    = h_l.min() + step3 * j
            upper    = lower + step3
            mid      = lower + step3/2
            voll     = volume_bins.get(j)
            valueVol = voll / volume_bins.max() * 50
            col      = close > mid ? buyColor : sellColor
            m_col    = color.from_gradient(voll, volume_bins.min(), volume_bins.max(), color.new(col, 80), color.new(col, 0))
            m_col1   = color.from_gradient(voll, volume_bins.min(), volume_bins.max(), color.new(col, 50), color.new(col, 0))

            isBuyBin    = close > mid
            isStrongest = (isBuyBin and j == maxBuyIdx) or (not isBuyBin and j == maxSellIdx)
            isMaxPoc    = voll == volume_bins.max() and poc

            if not (close < upper and close > lower)
                if displPf and (valueVol != 0)
                    boxes2.push(box.new(bar_index+20, upper, bar_index+20+int(valueVol), lower, bgcolor=voll == volume_bins.max() and poc ? maxColor : m_col, border_color=chart.bg_color, text=voll > volume_bins.avg() ? str.tostring(voll, format.volume) : "", text_halign=text.align_left))
                    boxes2.push(box.new(bar_index+20, upper, bar_index+5, lower, text=str.tostring(valueVol*2, format.percent), bgcolor=color(na), border_color=color(na), text_color=voll == volume_bins.max() ? maxColor : m_col1))

                var start = 0
                isLower = close > mid

                for i = 0 to lookBack - 1
                    if isLower
                        if low[i] < mid
                            start := bar_index - i
                            break
                        if i == lookBack - 1
                            start := bar_index - i
                            break
                    else
                        if high[i] > mid
                            start := bar_index - i
                            break
                        if i == lookBack - 1
                            start := bar_index - i
                            break

                lineColor = voll == volume_bins.max() and poc ? maxColor : color.from_gradient(valueVol, 0, 50, color(na), isLower ? color.new(buyColor, 30) : color.new(sellColor, 30))

                if isStrongest or isMaxPoc
                    lines2.push(line.new(start+3, mid, bar_index+5, mid, width=int(valueVol/5), color=lineColor))

    bgColorRSI2    = rsi2 > rsi2Upper ? color.new(color.green, 20) : rsi2 < rsi2Lower ? color.new(color.red, 20) : color.new(color.gray, 40)
    bgColorDemand2 = demandPerc2 > 60 ? color.new(color.green, 20) : demandPerc2 > 50 ? color.new(color.green, 60) : color.new(color.gray, 40)
    bgColorSupply2 = supplyPerc2 > 60 ? color.new(color.red,   20) : supplyPerc2 > 50 ? color.new(color.red,   60) : color.new(color.gray, 40)

    buyBgColor  = bull ? color.new(#23da3c, 40) : color.new(color.black, 20)
    sellBgColor = bull ? color.new(color.black, 20) : color.new(#ee1c1c, 40)

// ─── Data Table Settings ──────────────────────────────────────────────────────
var G4 = "Data Table"
dtbChk   = input.bool(true, "تفعيل الجدول؟", group = G4)
dtbLoc   = input.string("top_left", "الموقع",
           ["top_right","middle_right","bottom_right","top_center","middle_center",
            "bottom_center","top_left","middle_left","bottom_left"], group = G4)
dtbBgClr = input.color(color.new(color.black, 40), "BG", group = G4)
lookback = input.int(20, "عدد الشموع للحساب", minval = 1, maxval = 200, group = G4)

// ─── Helpers ──────────────────────────────────────────────────────────────────
formatVolume(float vol) =>
    if na(vol) or vol == 0
        "0"
    else if vol >= 1000000000
        str.tostring(math.round(vol / 1000000000, 2)) + "B"
    else if vol >= 1000000
        str.tostring(math.round(vol / 1000000, 2)) + "M"
    else if vol >= 1000
        str.tostring(math.round(vol / 1000, 2)) + "K"
    else
        str.tostring(math.round(vol, 2))

// ─── الحساب الصحيح بـ math.sum داخل request.security ─────────────────────────
calcBotCol(string tf, int lb) =>
    [botVol, colVol] = request.security(syminfo.tickerid, tf, [
         math.sum(close >= open ? volume : 0.0, lb),
         math.sum(close <  open ? volume : 0.0, lb)
         ], lookahead = barmerge.lookahead_off)
    [nz(botVol), nz(colVol)]

// الأطر المطلوبة (بدون 4 ساعات)
[bot1H, col1H] = calcBotCol("60",  lookback)  // 1 ساعة
[bot15, col15] = calcBotCol("15",  lookback)  // 15 دقيقة
[bot5,  col5]  = calcBotCol("5",   lookback)  // 5 دقائق

// ─── المجاميع المطلوبة ───────────────────────────────────────────────────────
totalUp   = bot1H + bot15 + bot5      // مجموع الصعود
totalDown = col1H + col15 + col5      // مجموع الهبوط
netResult = totalUp - totalDown       // النتيجة (الصافي)

// ─── Vol Tracker Table ────────────────────────────────────────────────────────
var table dtb = na

if barstate.islast and dtbChk
    if not na(dtb)
        dtb.delete()

    // جدول: 3 أعمدة × 4 صفوف (هيدر + 3 صفوف للمجاميع) - تم تصغير حجم الخط
    dtb := table.new(dtbLoc, 3, 4,
             bgcolor      = dtbBgClr,
             border_color = color.new(color.white, 75),
             border_width = 1,
             frame_color  = color.new(color.white, 65),
             frame_width  = 1)

    hBg  = color.new(color.black, 55)
    hClr = color.new(color.white, 5)

    // ─── هيدر (تم تصغير النص إلى tiny) ───────────────────────────────────────
    dtb.cell(0, 0, "البيان", text_color = hClr, bgcolor = hBg, text_size = size.tiny)
    dtb.cell(1, 0, "القيمة", text_color = hClr, bgcolor = hBg, text_size = size.tiny)
    dtb.cell(2, 0, "الاتجاه", text_color = hClr, bgcolor = hBg, text_size = size.tiny)

    // ─── مجموع الصعود (تم تصغير النص إلى tiny) ───────────────────────────────
    upBg = color.new(#1B5E20, 65)
    dtb.cell(0, 1,  " صعود ", text_color = color.new(#4CAF50, 0), bgcolor = color.new(color.gray, 75), text_size = size.tiny)
    dtb.cell(1, 1, formatVolume(totalUp), text_color = color.new(#00BFFF, 0), bgcolor = upBg, text_size = size.tiny)
    dtb.cell(2, 1, "↑", text_color = color.new(#4CAF50, 0), bgcolor = color.new(color.gray, 75), text_size = size.tiny)

    // ─── مجموع الهبوط (تم تصغير النص إلى tiny) ───────────────────────────────
    downBg = color.new(#B71C1C, 65)
    dtb.cell(0, 2,  " هبوط ", text_color = color.new(#F44336, 0), bgcolor = color.new(color.gray, 75), text_size = size.tiny)
    dtb.cell(1, 2, formatVolume(totalDown), text_color = color.new(#FF69B4, 0), bgcolor = downBg, text_size = size.tiny)
    dtb.cell(2, 2, "↓", text_color = color.new(#F44336, 0), bgcolor = color.new(color.gray, 75), text_size = size.tiny)

    // ─── النتيجة (الصافي) (تم تصغير النص إلى tiny) ───────────────────────────
    resultBg = netResult >= 0 ? color.new(#1B5E20, 65) : color.new(#B71C1C, 65)
    resultArrow = netResult >= 0 ? "↑" : "↓"
    resultColor = netResult >= 0 ? color.new(#4CAF50, 0) : color.new(#F44336, 0)
    
    dtb.cell(0, 3,  " صافي ", text_color = color.new(#d3c945, 0), bgcolor = color.new(color.gray, 75), text_size = size.tiny)
    dtb.cell(1, 3, formatVolume(math.abs(netResult)), text_color = resultColor, bgcolor = resultBg, text_size = size.tiny)
    dtb.cell(2, 3, resultArrow, text_color = resultColor, bgcolor = color.new(color.gray, 75), text_size = size.tiny)
    
// =====================
// TYPES
// =====================
type Settings
    string      htf
    bool        mirror
    int         max
    int         lookback
    string      override1
    float       overridevalue1
    string      override2
    float       overridevalue2
    string      override3
    float       overridevalue3
    string      override4
    float       overridevalue4
    string      override5
    float       overridevalue5

type FibLevels
    bool        show
    int         padding
    bool        useLog
    bool        use_background
    int         fill_percent
    bool        show_level
    bool        show_price
    string      label_size
    bool        fib1
    float       fib1_level
    color       fib1_color
    string      fib1_style
    int         fib1_size
    bool        fib2
    float       fib2_level
    color       fib2_color
    string      fib2_style
    int         fib2_size
    bool        fib3
    float       fib3_level
    color       fib3_color
    string      fib3_style
    int         fib3_size
    bool        fib4
    float       fib4_level
    color       fib4_color
    string      fib4_style
    int         fib4_size
    bool        fib5
    float       fib5_level
    color       fib5_color
    string      fib5_style
    int         fib5_size
    bool        fib6
    float       fib6_level
    color       fib6_color
    string      fib6_style
    int         fib6_size
    bool        fib7
    float       fib7_level
    color       fib7_color
    string      fib7_style
    int         fib7_size
    bool        fib8
    float       fib8_level
    color       fib8_color
    string      fib8_style
    int         fib8_size
    bool        fib9
    float       fib9_level
    color       fib9_color
    string      fib9_style
    int         fib9_size

type fib
    float       level
    float       price
    color       color
    string      style
    int         size
    line        ln
    label       lbl
    linefill    fl

type Daily
    array<fib>  fibs
    float       price
    int         time
    int         time_last

type Candle
    float       o
    float       c
    float       h
    float       l
    int         o_idx
    int         c_idx
    int         h_idx
    int         l_idx
    box         body
    line        wick_up
    line        wick_down

type CandleSettings
    bool        show
    string      htf
    int         max_display

type HTFSettings
    int         max_sets
    color       bull_body
    color       bull_border
    color       bull_wick
    color       bear_body
    color       bear_border
    color       bear_wick
    int         offset
    int         buffer
    int         htf_buffer
    int         width
    bool        htf_label_show
    color       htf_label_color
    string      htf_label_size

type CandleSet
    Candle[]        candles
    CandleSettings  settings
    label           tfName

type VolumeData
    float totalVol

type orderblock
    float      value
    int        barStart
    int        barEnd
    box        block
    label      lbl
    label      signalLbl
    bool       broken
    VolumeData volumeData

// =====================
// INPUTS - fmfmf16
// =====================
settings_panel  = 'لوحة التحكم ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━'
show_indicator  = input.bool(true, '👁 إظهار المؤشر كاملاً', group = settings_panel)

settings_tf     = 'لوحة الفريمات ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━'
selected_tf     = input.string('240', 'الفريم الزمني', options = ['60', '240', 'D'], group = settings_tf)

settings_targets = 'الأهداف ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━'
fib_line_style  = input.string('⎯⎯⎯', 'نمط الخطوط', options = ['⎯⎯⎯', '----', '····'], group = settings_targets)
fib_label_size  = input.string(size.small, 'حجم الأسعار', options = [size.tiny, size.small, size.normal, size.large], group = settings_targets)
show_prices_lbl = input.bool(true, 'إظهار الأسعار', group = settings_targets)

settings_tools  = 'الأدوات ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━'
showFVG         = input.bool(true,  'إظهار صناديق سيولة',         group = settings_tools)
maxBoxes        = input.int(1, 'عدد صناديق سيولة', minval=1, maxval=10, group = settings_tools)
showOB          = input.bool(true,  'إظهار مناطق العرض والطلب',   group = settings_tools)
